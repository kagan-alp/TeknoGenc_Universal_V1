import streamlit as st
import random
import time

# =================================================================
# 1. J.A.R.V.I.S. HUD INTERFACE (UI DESIGN)
# =================================================================
st.set_page_config(page_title="TG KAĞAN - STARK CORE", page_icon="🦾", layout="wide")

st.markdown("""
<style>
/* Saf Beyaz Stark Minimalizmi */
.stApp {
    background-color: #ffffff;
    color: #1c1c1e;
    font-family: -apple-system, sans-serif;
}

/* Üst Panel: Roket ve Kimlik */
.stark-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 0;
    border-bottom: 1px solid #f2f2f7;
    margin-bottom: 30px;
}
.identity { display: flex; align-items: center; gap: 12px; }
.identity img { width: 35px; filter: grayscale(1); }
.identity span { font-weight: 700; font-size: 18px; letter-spacing: 1px; color: #000; }

/* Merhaba Bölümü */
.welcome-container { margin: 40px 0; }
.welcome-title { font-size: 24px; font-weight: 300; color: #000; }
.welcome-sub { font-size: 14px; color: #8e8e93; margin-top: 4px; }

/* JARVIS Mesaj Balonları */
.chat-container { display: flex; flex-direction: column; gap: 15px; }
.msg-row { display: flex; width: 100%; }
.msg-row.user { justify-content: flex-end; }
.msg-row.ai { justify-content: flex-start; }

.bubble {
    padding: 12px 18px;
    border-radius: 18px;
    max-width: 80%;
    font-size: 16px;
    line-height: 1.5;
}

.user .bubble {
    background-color: #007aff;
    color: #ffffff;
    border-bottom-right-radius: 2px;
}

.ai .bubble {
    background-color: #f2f2f7;
    color: #1c1c1e;
    border-bottom-left-radius: 2px;
    border-left: 3px solid #000; /* JARVIS İmzası */
}

/* Input Alanı Temizliği */
div[data-testid="stChatInput"] { background-color: transparent !important; }
div[data-testid="stChatInput"] textarea {
    border-radius: 20px !important;
    border: 1px solid #d1d1d6 !important;
    padding: 12px !important;
}

/* Gizlenen Gereksiz Öğeler */
[data-testid="stSidebar"] { display: none; }
header, footer { visibility: hidden; }
</style>
""", unsafe_allow_html=True)

# =================================================================
# 2. SİSTEM ÇEKİRDEĞİ (CORE)
# =================================================================
if "messages" not in st.session_state:
    st.session_state.messages = []

# =================================================================
# 3. HUD (HEAD-UP DISPLAY) ÜST PANEL
# =================================================================
col_id, col_plus = st.columns([10, 1])

with col_id:
    st.markdown("""
        <div class="stark-header">
            <div class="identity">
                <img src="https://upload.wikimedia.org/wikipedia/commons/e/e9/Teknofest_logo.png">
                <span>TG KAĞAN</span>
            </div>
        </div>
    """, unsafe_allow_html=True)

with col_plus:
    if st.button("➕", help="Yeni Oturum Başlat"):
        st.session_state.messages = []
        st.rerun()

# =================================================================
# 4. SİSTEM DURUMU / MERHABA
# =================================================================
if not st.session_state.messages:
    st.markdown("""
        <div class="welcome-container">
            <div class="welcome-title">Merhaba</div>
            <div class="welcome-sub">Size nasıl yardımcı olabilirim?</div>
        </div>
    """, unsafe_allow_html=True)

# Sohbet Geçmişi ve Başlık Menüsü Simülasyonu
for i, msg in enumerate(st.session_state.messages):
    role_class = "user" if msg["role"] == "user" else "ai"
    
    # Sohbet Başlığı ve Seçenekler (Expander ile)
    if msg["role"] == "user":
        with st.expander(f"📁 Dosya: {msg['content'][:25]}..."):
            c1, c2, c3 = st.columns(3)
            if c1.button("Paylaş", key=f"s_{i}"): st.toast("Sohbet şifrelendi ve paylaşıldı.")
            if c2.button("Adlandır", key=f"r_{i}"): st.toast("Proje yeniden adlandırıldı.")
            if c3.button("Sabitle", key=f"p_{i}"): st.toast("HUD ekranına sabitlendi.")

    st.markdown(f'<div class="msg-row {role_class}"><div class="bubble">{msg["content"]}</div></div>', unsafe_allow_html=True)

# =================================================================
# 5. JARVIS MANTIKSAL CEVAP MOTORU (FILM MODU)
# =================================================================
if prompt := st.chat_input("Komutunuzu bekliyorum..."):
    st.session_state.messages.append({"role": "user", "content": prompt})
    
    # JARVIS Kişiliği
    p = prompt.lower()
    
    # Filmdeki gibi zırh ve durum bazlı yanıtlar
    if any(x in p for x in ["selam", "merhaba", "günaydın"]):
        cevap = "Merhaba efendim. Tüm sistemler çevrimiçi. Zırhın enerji seviyesi %100. Sizi dinliyorum, nereden başlayalım?"
    
    elif any(x in p for x in ["durum", "nasılsın", "sistem"]):
        cevap = "Bilişsel çekirdeğim stabil. Arka planda uçuş rotalarını analiz ediyorum. Sizin için yapabileceğim özel bir şey var mı?"

    elif any(x in p for x in ["hava", "dışarısı"]):
        cevap = "Bölgenizdeki atmosferik basınç normal. Gökyüzü uçuş için elverişli görünüyor efendim. Zırhın termal modunu aktif etmemi ister misiniz?"

    elif any(x in p for x in ["zırh", "silah", "mark"]):
        cevap = "Mark 85 savunma protokolleri hazırlandı. Hedefleme sistemleri kalibre edildi. Emirlerinizi bekliyorum."

    else:
        # Standart ama karakterli yanıtlar
        jarvis_lines = [
            "Anlaşıldı efendim. Verileri analiz ediyorum, sizi dinliyorum.",
            "Talebiniz işleniyor. Stark veri tabanında ilgili dosyaları tarıyorum. Sizi dinliyorum.",
            "Stratejik bir hamle gibi görünüyor. Detayları paylaşırsanız simülasyonu başlatabilirim.",
            "Zihninizdeki planı gerçekleştirmek için tüm işlem gücümü size ayırdım. Sizi dinliyorum."
        ]
        cevap = random.choice(jarvis_lines)

    st.session_state.messages.append({"role": "assistant", "content": cevap})
    st.rerun()
