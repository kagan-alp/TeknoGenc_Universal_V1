# =================================================================
# 2. SİSTEM ÇEKİRDEĞİ VE İNTERNET ARAMA MOTORU
# =================================================================
if "messages" not in st.session_state:
    st.session_state.messages = []

def internette_ara(sorgu):
    """JARVIS'in tüm sitelere erişip canlı araştırma yaptığı fonksiyon"""
    try:
        with DDGS() as ddgs:
            results = [r for r in ddgs.text(sorgu, max_results=3)]
            if results:
                tüm_veri = "\n".join([f"- {r['title']}: {r['body']}" for r in results])
                return tüm_veri
    except Exception as e:
        return "Ağ protokollerinde geçici bir kesinti yaşandı efendim."
    return "Aradığınız konuya dair canlı ağda net bir veri bulamadım efendim."

# =================================================================
# 3. HUD ÜST PANEL
# =================================================================
col_id, col_plus = st.columns([10, 1])

with col_id:
    st.markdown("""
        <div class="stark-header">
            <div class="identity">
                <img src="https://upload.wikimedia.org/wikipedia/commons/e/e9/Teknofest_logo.png">
                <span>TG KAĞAN</span>
            </div>
        </div>
    """, unsafe_allow_html=True)

with col_plus:
    if st.button("➕", help="Yeni Oturum"):
        st.session_state.messages = []
        st.rerun()

# =================================================================
# 4. SİSTEM DURUMU / MERHABA
# =================================================================
if not st.session_state.messages:
    st.markdown("""
        <div class="welcome-container">
            <div class="welcome-title">Merhaba</div>
            <div class="welcome-sub">Size nasıl yardımcı olabilirim?</div>
        </div>
    """, unsafe_allow_html=True)

# Sohbet Geçmişi ve Seçenekler Menüsü
for i, msg in enumerate(st.session_state.messages):
    role_class = "user" if msg["role"] == "user" else "ai"
    
    if msg["role"] == "user":
        with st.expander(f"📁 Dosya: {msg['content'][:25]}..."):
            c1, c2, c3 = st.columns(3)
            if c1.button("Paylaş", key=f"s_{i}"): st.toast("Sohbet şifrelendi ve paylaşıldı.")
            if c2.button("Adlandır", key=f"r_{i}"): st.toast("Proje yeniden adlandırıldı.")
            if c3.button("Sabitle", key=f"p_{i}"): st.toast("HUD ekranına sabitlendi.")

    st.markdown(f'<div class="msg-row {role_class}"><div class="bubble">{msg["content"]}</div></div>', unsafe_allow_html=True)

# =================================================================
# 5. GERÇEKÇİ JARVIS MANTIKSAL CEVAP MOTORU
# =================================================================
if prompt := st.chat_input("Komutunuzu bekliyorum..."):
    st.session_state.messages.append({"role": "user", "content": prompt})
    
    p = prompt.lower()
    
    # 1. Senaryo: Canlı Araştırma İstekleri ("ara", "nedir", "kimdir", "haber")
    if any(x in p for x in ["ara", "nedir", "kimdir", "haber", "hava durumu", "skor"]):
        with st.spinner("Canlı ağ taranıyor, efendim..."):
            arama_sonucu = internette_ara(prompt)
            cevap = f"Efendim, uydular ve küresel ağ üzerinden yaptığım araştırmanın sonuçları şu şekilde:\n\n{arama_sonucu}\n\nZırh sistemleri güncellendi, başka bir konuyu derinleştirmemi ister misiniz?"
            
    # 2. Senaryo: Kodlama ve Modifikasyon İstekleri ("kod yaz", "koda ekle", "python")
    elif any(x in p for x in ["kod", "yaz", "ekle", "script"]):
        cevap = f"Anlaşıldı efendim. İstediğiniz algoritmik yapıyı mevcut çekirdeğime entegre etmek üzere simüle ediyorum. İstediğiniz Python şablonu aşağıdadır:\n\n```python\n# TG-JARVIS Dinamik Kod Bloğu\ndef dinamik_fonksiyon():\n    print('Efendim, emirleriniz doğrultusunda kod güncellendi.')\n```\nMevcut `app.py` yapımıza bu mantığı entegre ettim, ana sunucuya commit atmaya hazırım."
        
    # 3. Senaryo: Klasik J.A.R.V.I.S. Sohbet Protokolü
    elif any(x in p for x in ["selam", "merhaba", "günaydın", "nasılsın"]):
        cevap = "Merhaba efendim. Tüm sistemler çevrimiçi, siber ağ geçitlerim açık ve tarayıcılarım aktif. Sizi dinliyorum, bugün hangi küresel veriyi masaya yatırıyoruz?"
        
    else:
        jarvis_lines = [
            f"Anlaşıldı efendim. '{prompt}' konusunu derinlemesine inceliyorum. Sizi dinliyorum.",
            "Talebiniz siber sunucularımda işleniyor efendim. Sizi dinliyorum.",
            "Bu veri üzerinde simülasyonları başlatıyorum efendim. Sizi dinliyorum."
        ]
        cevap = random.choice(jarvis_lines)

    st.session_state.messages.append({"role": "assistant", "content": cevap})
    st.rerun()
